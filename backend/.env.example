# Backend environment variables
PORT=5000

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_UNIT_AMOUNT=2400
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Frontend origin used for Stripe checkout success/cancel URLs
FRONTEND_URL=http://localhost:5173

# Gmail / SMTP (order email notifications)
GMAIL_USER=you@example.com
GMAIL_APP_PASSWORD=replace-with-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Google Sheets service account JSON file path
GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json
